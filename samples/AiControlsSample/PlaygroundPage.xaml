<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Microsoft.Maui.AI.Controls.Controls;assembly=Microsoft.Maui.AI.Controls"
             x:Class="AiControlsSample.PlaygroundPage"
             Title="Playground"
             Shell.NavBarIsVisible="True">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🗑️ Clear" Clicked="OnClearChatClicked" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="RootLayout" ColumnDefinitions="*,Auto">

        <!-- Chat fills available space -->
        <controls:AgentChatView
            x:Name="ChatView"
            WelcomeTitle="AI Assistant"
            WelcomeIcon="🤖"
            WelcomeMessage="I can check the weather, do math, and share fun facts. Try asking!"
            Placeholder="Ask me anything..."
            UserDisplayName="You"
            AssistantDisplayName="Copilot"
            UserAvatarText="You"
            AssistantAvatarText="AI"
            ShowAvatars="True"
            ShowTimestamps="True" />

        <!-- Settings panel: docked sidebar, auto-hidden on narrow -->
        <Border x:Name="SettingsPanel" Grid.Column="1"
                IsVisible="True"
                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A1A2E}"
                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                StrokeShape="Rectangle"
                StrokeThickness="1"
                Padding="0">
            <Grid RowDefinitions="Auto,*">
                <!-- Header -->
                <Grid Padding="16,14"
                      BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#262640}">
                    <Label Text="⚙️ Settings" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>

                <!-- Settings content -->
                <ScrollView Grid.Row="1" Padding="12,8,12,16">
                    <VerticalStackLayout Spacing="6">

                        <!-- ═══ WELCOME ═══ -->
                        <Border x:Name="WelcomeSection" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                BackgroundColor="Transparent" Padding="4">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="▼ WELCOME" FontSize="10" FontAttributes="Bold" Opacity="0.5">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSectionHeaderTapped" CommandParameter="WelcomeContent" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <VerticalStackLayout x:Name="WelcomeContent" Spacing="6">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Icon" FontSize="11" Opacity="0.7" />
                                        <Entry x:Name="WelcomeIconEntry" Text="🤖" MaxLength="4" FontSize="13" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Title" FontSize="11" Opacity="0.7" />
                                        <Entry x:Name="WelcomeTitleEntry" Text="AI Assistant" FontSize="13" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Message" FontSize="11" Opacity="0.7" />
                                        <Entry x:Name="WelcomeMessageEntry" Text="I can check the weather, do math, and share fun facts. Try asking!" FontSize="13" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Placeholder" FontSize="11" Opacity="0.7" />
                                        <Entry x:Name="PlaceholderEntry" Text="Ask me anything..." FontSize="13" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />

                        <!-- ═══ IDENTITY ═══ -->
                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                BackgroundColor="Transparent" Padding="4">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="▼ IDENTITY" FontSize="10" FontAttributes="Bold" Opacity="0.5">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSectionHeaderTapped" CommandParameter="IdentityContent" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <VerticalStackLayout x:Name="IdentityContent" Spacing="6">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Your Name" FontSize="11" Opacity="0.7" />
                                            <Entry x:Name="UserNameEntry" Text="You" FontSize="13" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="Avatar" FontSize="11" Opacity="0.7" />
                                            <Entry x:Name="UserAvatarEntry" Text="You" MaxLength="3" FontSize="13" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Assistant" FontSize="11" Opacity="0.7" />
                                            <Entry x:Name="AssistantNameEntry" Text="Copilot" FontSize="13" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="Avatar" FontSize="11" Opacity="0.7" />
                                            <Entry x:Name="AssistantAvatarEntry" Text="AI" MaxLength="3" FontSize="13" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                        <Label Text="Show Avatars" VerticalOptions="Center" FontSize="13" />
                                        <Switch x:Name="ShowAvatarsSwitch" IsToggled="True" Grid.Column="1" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                        <Label Text="Show Timestamps" VerticalOptions="Center" FontSize="13" />
                                        <Switch x:Name="ShowTimestampsSwitch" IsToggled="True" Grid.Column="1" />
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />

                        <!-- ═══ APPEARANCE ═══ -->
                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                BackgroundColor="Transparent" Padding="4">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="▼ APPEARANCE" FontSize="10" FontAttributes="Bold" Opacity="0.5">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSectionHeaderTapped" CommandParameter="AppearanceContent" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <VerticalStackLayout x:Name="AppearanceContent" Spacing="6">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Bubble Style" FontSize="11" Opacity="0.7" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Button x:Name="BubbleSharpBtn" Text="Sharp" FontSize="11" Padding="8,4" CornerRadius="4"
                                                    BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" Clicked="OnBubbleStyleClicked" />
                                            <Button x:Name="BubbleRoundedBtn" Text="Rounded" FontSize="11" Padding="8,4" CornerRadius="4"
                                                    BackgroundColor="{AppThemeBinding Light=#6366F1, Dark=#818CF8}" TextColor="White" Clicked="OnBubbleStyleClicked" />
                                            <Button x:Name="BubblePillBtn" Text="Pill" FontSize="11" Padding="8,4" CornerRadius="4"
                                                    BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" Clicked="OnBubbleStyleClicked" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Bubble Border" FontSize="11" Opacity="0.7" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Button x:Name="StrokeNoneBtn" Text="None" FontSize="11" Padding="8,4" CornerRadius="4"
                                                    BackgroundColor="{AppThemeBinding Light=#6366F1, Dark=#818CF8}" TextColor="White" Clicked="OnStrokeStyleClicked" />
                                            <Button x:Name="StrokeThinBtn" Text="Thin" FontSize="11" Padding="8,4" CornerRadius="4"
                                                    BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" Clicked="OnStrokeStyleClicked" />
                                            <Button x:Name="StrokeBoldBtn" Text="Bold" FontSize="11" Padding="8,4" CornerRadius="4"
                                                    BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" Clicked="OnStrokeStyleClicked" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                        <Label Text="Show Tool Calls" VerticalOptions="Center" FontSize="13" />
                                        <Switch x:Name="ShowToolMessagesSwitch" IsToggled="True" Grid.Column="1" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                        <Label Text="Show Reasoning" VerticalOptions="Center" FontSize="13" />
                                        <Switch x:Name="ShowReasoningSwitch" IsToggled="True" Grid.Column="1" />
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />

                        <!-- ═══ TOOLS ═══ -->
                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                BackgroundColor="Transparent" Padding="4">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="▼ TOOLS" FontSize="10" FontAttributes="Bold" Opacity="0.5">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSectionHeaderTapped" CommandParameter="ToolsContent" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <VerticalStackLayout x:Name="ToolsContent" Spacing="6">
                                    <HorizontalStackLayout Spacing="6">
                                        <Border StrokeShape="RoundRectangle 12" Padding="10,6" 
                                                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                            <Label Text="🌤 Weather" FontSize="12" LineBreakMode="NoWrap" />
                                        </Border>
                                        <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                            <Label Text="🔢 Calculate" FontSize="12" LineBreakMode="NoWrap" />
                                        </Border>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="6">
                                        <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                            <Label Text="💡 Fact" FontSize="12" LineBreakMode="NoWrap" />
                                        </Border>
                                        <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                            <Label Text="📱 App Info" FontSize="12" LineBreakMode="NoWrap" />
                                        </Border>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
