<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Microsoft.Maui.AI.Controls.Controls;assembly=Microsoft.Maui.AI.Controls"
             x:Class="AiControlsSample.PlaygroundPage"
             Title="Playground"
             Shell.NavBarIsVisible="True">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🗑️ Clear" Clicked="OnClearChatClicked" />
        <ToolbarItem Text="⚙️" Clicked="OnSettingsToggleClicked" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="RootLayout">

        <!-- Chat fills available space -->
        <controls:AgentChatView
            x:Name="ChatView"
            WelcomeTitle="AI Assistant"
            WelcomeIcon="🤖"
            WelcomeMessage="I can check the weather, do math, and share fun facts. Try asking!"
            Placeholder="Ask me anything..."
            UserDisplayName="You"
            AssistantDisplayName="Copilot"
            UserAvatarText="You"
            AssistantAvatarText="AI"
            ShowAvatars="True" />

        <!-- Settings panel: docked sidebar on wide, popup on narrow -->
        <Border x:Name="SettingsPanel" Grid.Column="1"
                IsVisible="False"
                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A1A2E}"
                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                StrokeShape="Rectangle"
                StrokeThickness="1"
                Padding="0"
                MinimumWidthRequest="220"
                MaximumWidthRequest="320">
            <Grid RowDefinitions="Auto,*">
                <!-- Header -->
                <Grid Padding="16,14" ColumnDefinitions="*,Auto"
                      BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#262640}">
                    <Label Text="⚙️ Settings" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="✕" FontSize="13"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                            Clicked="OnCloseSettingsClicked"
                            WidthRequest="28" HeightRequest="28" Padding="0" />
                </Grid>

                <!-- Settings content -->
                <ScrollView Grid.Row="1" Padding="16,8,16,16">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="GENERAL" FontSize="10" FontAttributes="Bold" Opacity="0.5" Margin="0,4,0,0" />
                        <VerticalStackLayout Spacing="8">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Welcome Icon" FontSize="11" Opacity="0.7" />
                                <Entry x:Name="WelcomeIconEntry" Text="🤖" MaxLength="4" FontSize="13" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Welcome Title" FontSize="11" Opacity="0.7" />
                                <Entry x:Name="WelcomeTitleEntry" Text="AI Assistant" FontSize="13" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Placeholder" FontSize="11" Opacity="0.7" />
                                <Entry x:Name="PlaceholderEntry" Text="Ask me anything..." FontSize="13" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                        <Label Text="IDENTITY" FontSize="10" FontAttributes="Bold" Opacity="0.5" Margin="0,8,0,0" />
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Your Name" FontSize="11" Opacity="0.7" />
                                    <Entry x:Name="UserNameEntry" Text="You" FontSize="13" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Avatar" FontSize="11" Opacity="0.7" />
                                    <Entry x:Name="UserAvatarEntry" Text="You" MaxLength="3" FontSize="13" />
                                </VerticalStackLayout>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Assistant" FontSize="11" Opacity="0.7" />
                                    <Entry x:Name="AssistantNameEntry" Text="Copilot" FontSize="13" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Avatar" FontSize="11" Opacity="0.7" />
                                    <Entry x:Name="AssistantAvatarEntry" Text="AI" MaxLength="3" FontSize="13" />
                                </VerticalStackLayout>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Text="Show Avatars" VerticalOptions="Center" FontSize="13" />
                                <Switch x:Name="ShowAvatarsSwitch" IsToggled="True" Grid.Column="1" />
                            </Grid>
                        </VerticalStackLayout>

                        <Label Text="TOOLS" FontSize="10" FontAttributes="Bold" Opacity="0.5" Margin="0,8,0,0" />
                        <VerticalStackLayout Spacing="6">
                            <HorizontalStackLayout Spacing="6">
                                <Border StrokeShape="RoundRectangle 12" Padding="10,6" 
                                        BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                    <Label Text="🌤 Weather" FontSize="12" LineBreakMode="NoWrap" />
                                </Border>
                                <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                        BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                    <Label Text="🔢 Calculate" FontSize="12" LineBreakMode="NoWrap" />
                                </Border>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6">
                                <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                        BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                    <Label Text="💡 Fact" FontSize="12" LineBreakMode="NoWrap" />
                                </Border>
                                <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                        BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                    <Label Text="📱 App Info" FontSize="12" LineBreakMode="NoWrap" />
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
