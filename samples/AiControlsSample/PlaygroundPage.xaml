<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Microsoft.Maui.AI.Chat.Controls;assembly=Microsoft.Maui.AI.Chat.Controls"
             xmlns:chat="clr-namespace:Microsoft.Maui.AI.Chat.Controls;assembly=Microsoft.Maui.AI.Chat.Controls"
             x:Class="AiControlsSample.PlaygroundPage"
             x:Name="ThisPage"
             Title="Playground"
             Shell.NavBarIsVisible="True">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🗑️ Clear" Clicked="OnClearChatClicked" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="RootLayout" ColumnDefinitions="*,Auto">

        <!-- Chat fills available space -->
        <controls:CopilotChatView x:Name="ChatPanel"
            Session="{Binding Source={x:Reference ThisPage}, Path=Session}"
            WelcomeMessage="Hello! I'm your AI assistant. Ask me about the weather, math, random facts, or app info."
            WelcomeIcon="🤖"
            Placeholder="Ask anything..."
            ShowTimestamps="False"
            ShowAvatars="False"
            ShowToolCalls="True"
            ShowToolResults="True">
            <controls:CopilotChatView.SuggestionPrompts>
                <x:String>What's the weather in Tokyo?</x:String>
                <x:String>Calculate (42 * 3) + 7</x:String>
                <x:String>Tell me a random fact</x:String>
                <x:String>What app am I running?</x:String>
            </controls:CopilotChatView.SuggestionPrompts>
            <controls:CopilotChatView.ContentTemplates>
                <chat:TextContentTemplate Role="User" />
                <chat:TextContentTemplate Role="Assistant" />
                <chat:FunctionCallTemplate />
                <chat:FunctionResultTemplate />
                <chat:ToolApprovalTemplate />
                <chat:ErrorContentTemplate />
                <chat:DefaultContentTemplate />
            </controls:CopilotChatView.ContentTemplates>
        </controls:CopilotChatView>

        <!-- Settings panel: docked sidebar -->
        <Border x:Name="SettingsPanel" Grid.Column="1"
                IsVisible="True"
                BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A1A2E}"
                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                StrokeShape="Rectangle"
                StrokeThickness="1"
                Padding="0">
            <Grid RowDefinitions="Auto,*">
                <!-- Header -->
                <Grid Padding="16,14"
                      BackgroundColor="{AppThemeBinding Light=#F1F5F9, Dark=#262640}">
                    <Label Text="⚙️ Settings" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>

                <!-- Settings content -->
                <ScrollView Grid.Row="1" Padding="12,8,12,16">
                    <VerticalStackLayout Spacing="6">

                        <!-- ═══ SESSION ═══ -->
                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                BackgroundColor="Transparent" Padding="4">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="▼ SESSION" FontSize="10" FontAttributes="Bold" Opacity="0.5">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSectionHeaderTapped" CommandParameter="SessionContent" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <VerticalStackLayout x:Name="SessionContent" Spacing="6">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="System Prompt" FontSize="11" Opacity="0.7" />
                                        <Editor x:Name="SystemPromptEditor" HeightRequest="80" FontSize="12"
                                                Text="You are a helpful assistant with access to tools for weather, math, facts, and app info." />
                                    </VerticalStackLayout>
                                    <Button Text="Apply System Prompt" FontSize="11" Padding="8,4"
                                            CornerRadius="6" Clicked="OnApplySystemPromptClicked"
                                            BackgroundColor="{AppThemeBinding Light=#6366F1, Dark=#818CF8}"
                                            TextColor="White" />
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Placeholder Text" FontSize="11" Opacity="0.7" />
                                        <Entry x:Name="PlaceholderEntry" Text="Ask anything..." FontSize="12"
                                               TextChanged="OnPlaceholderChanged" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Welcome Message" FontSize="11" Opacity="0.7" />
                                        <Entry x:Name="WelcomeEntry"
                                               Text="Hello! I'm your AI assistant. Ask me about the weather, math, random facts, or app info."
                                               FontSize="12"
                                               TextChanged="OnWelcomeMessageChanged" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />

                        <!-- ═══ DISPLAY ═══ -->
                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                BackgroundColor="Transparent" Padding="4">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="▼ DISPLAY" FontSize="10" FontAttributes="Bold" Opacity="0.5">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSectionHeaderTapped" CommandParameter="DisplayContent" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <VerticalStackLayout x:Name="DisplayContent" Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Show Timestamps" FontSize="12" VerticalOptions="Center" />
                                        <Switch x:Name="TimestampsSwitch" Grid.Column="1"
                                                Toggled="OnTimestampsToggled" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Show Tool Calls" FontSize="12" VerticalOptions="Center" />
                                        <Switch x:Name="ToolCallsSwitch" Grid.Column="1" IsToggled="True"
                                                Toggled="OnToolCallsToggled" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Show Tool Results" FontSize="12" VerticalOptions="Center" />
                                        <Switch x:Name="ToolResultsSwitch" Grid.Column="1" IsToggled="True"
                                                Toggled="OnToolResultsToggled" />
                                    </Grid>
                                    <VerticalStackLayout Spacing="2">
                                        <Label FontSize="11" Opacity="0.7">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Bubble Corner Radius: " />
                                                    <Span x:Name="CornerRadiusValue" Text="16" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Slider x:Name="CornerRadiusSlider" Minimum="0" Maximum="24"
                                                Value="16" ValueChanged="OnCornerRadiusChanged" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="2">
                                        <Label FontSize="11" Opacity="0.7">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="Max Bubble Width: " />
                                                    <Span x:Name="MaxWidthValue" Text="340" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Slider x:Name="MaxWidthSlider" Minimum="200" Maximum="600"
                                                Value="340" ValueChanged="OnMaxWidthChanged" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />

                        <!-- ═══ TOOLS ═══ -->
                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                BackgroundColor="Transparent" Padding="4">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="▼ TOOLS" FontSize="10" FontAttributes="Bold" Opacity="0.5">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSectionHeaderTapped" CommandParameter="ToolsContent" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <VerticalStackLayout x:Name="ToolsContent" Spacing="6">
                                    <Label Text="Available tools:" FontSize="12" Opacity="0.7" />
                                    <HorizontalStackLayout Spacing="6">
                                        <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                            <Label Text="🌤 Weather" FontSize="12" LineBreakMode="NoWrap" />
                                        </Border>
                                        <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                            <Label Text="🔢 Calculate" FontSize="12" LineBreakMode="NoWrap" />
                                        </Border>
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="6">
                                        <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                            <Label Text="💡 Fact" FontSize="12" LineBreakMode="NoWrap" />
                                        </Border>
                                        <Border StrokeShape="RoundRectangle 12" Padding="10,6"
                                                BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}" StrokeThickness="0">
                                            <Label Text="📱 App Info" FontSize="12" LineBreakMode="NoWrap" />
                                        </Border>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />

                        <!-- ═══ QUICK PROMPTS ═══ -->
                        <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                BackgroundColor="Transparent" Padding="4">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="▼ QUICK PROMPTS" FontSize="10" FontAttributes="Bold" Opacity="0.5">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSectionHeaderTapped" CommandParameter="PromptsContent" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <VerticalStackLayout x:Name="PromptsContent" Spacing="6">
                                    <Button Text="🌤 What's the weather in Tokyo?" FontSize="11" Padding="8,6"
                                            CornerRadius="8" Clicked="OnQuickPromptClicked"
                                            BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}"
                                            TextColor="{AppThemeBinding Light=#4338CA, Dark=#A5B4FC}" />
                                    <Button Text="🔢 Calculate (42 * 3) + 7" FontSize="11" Padding="8,6"
                                            CornerRadius="8" Clicked="OnQuickPromptClicked"
                                            BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}"
                                            TextColor="{AppThemeBinding Light=#4338CA, Dark=#A5B4FC}" />
                                    <Button Text="💡 Tell me a random fact" FontSize="11" Padding="8,6"
                                            CornerRadius="8" Clicked="OnQuickPromptClicked"
                                            BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}"
                                            TextColor="{AppThemeBinding Light=#4338CA, Dark=#A5B4FC}" />
                                    <Button Text="📱 What app am I running?" FontSize="11" Padding="8,6"
                                            CornerRadius="8" Clicked="OnQuickPromptClicked"
                                            BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#312E81}"
                                            TextColor="{AppThemeBinding Light=#4338CA, Dark=#A5B4FC}" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
