<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AiControlsSample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AiControlsSample"
    Title="AI Controls"
    FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#1A1A2E}"
    Shell.NavBarIsVisible="True"
    Shell.BackgroundColor="{AppThemeBinding Light=#6366F1, Dark=#312E81}"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.UnselectedColor="{AppThemeBinding Light=#94A3B8, Dark=#64748B}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E2E}">

    <Shell.FlyoutHeader>
        <Grid Padding="20,40,20,20" BackgroundColor="{AppThemeBinding Light=#6366F1, Dark=#312E81}">
            <VerticalStackLayout Spacing="4">
                <Label Text="🤖" FontSize="32" />
                <Label Text="AI Controls" FontSize="18" FontAttributes="Bold" TextColor="White" />
                <Label Text="MAUI Chat Sample" FontSize="12" TextColor="#C7D2FE" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="💬  Playground" Route="playground">
        <ShellContent ContentTemplate="{DataTemplate local:PlaygroundPage}" />
    </FlyoutItem>
    <FlyoutItem Title="🎨  Agentic Chat" Route="agentic-chat">
        <ShellContent ContentTemplate="{DataTemplate local:AgenticChatPage}" />
    </FlyoutItem>
    <FlyoutItem Title="🔧  Tool Rendering" Route="tool-rendering">
        <ShellContent ContentTemplate="{DataTemplate local:ToolRenderingPage}" />
    </FlyoutItem>
    <FlyoutItem Title="📋  Human in the Loop" Route="hitl">
        <ShellContent ContentTemplate="{DataTemplate local:HumanInTheLoopPage}" />
    </FlyoutItem>
    <FlyoutItem Title="🍳  Shared State" Route="shared-state">
        <ShellContent ContentTemplate="{DataTemplate local:SharedStatePage}" />
    </FlyoutItem>
    <FlyoutItem Title="🚀  Agentic Gen UI" Route="agentic-genui">
        <ShellContent ContentTemplate="{DataTemplate local:AgenticGenerativeUIPage}" />
    </FlyoutItem>
    <FlyoutItem Title="✍️  Predictive State" Route="predictive-state">
        <ShellContent ContentTemplate="{DataTemplate local:PredictiveStatePage}" />
    </FlyoutItem>
    <FlyoutItem Title="🎋  Haiku Generator" Route="haiku">
        <ShellContent ContentTemplate="{DataTemplate local:HaikuPage}" />
    </FlyoutItem>

</Shell>
