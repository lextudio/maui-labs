<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Microsoft.Maui.AI.Controls.Controls;assembly=Microsoft.Maui.AI.Controls"
             x:Class="AiControlsSample.AgenticChatPage"
             x:Name="ThisPage"
             Title="Agentic Chat">

    <Grid x:Name="PageRoot"
          BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}">
        <controls:AgentChatView
            x:Name="ChatView"
            WelcomeTitle="Agentic Chat"
            WelcomeIcon="🎨"
            WelcomeMessage="I can change the background color of this page! Try asking me."
            Placeholder="Try 'Change background to light blue'..."
            AssistantDisplayName="Agent"
            AssistantAvatarText="🎨" />
    </Grid>
</ContentPage>
