<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Microsoft.Maui.AI.Chat.Controls;assembly=Microsoft.Maui.AI.Chat.Controls"
             xmlns:chat="clr-namespace:Microsoft.Maui.AI.Chat.Controls;assembly=Microsoft.Maui.AI.Chat.Controls"
             xmlns:local="clr-namespace:AiControlsSample"
             x:Class="AiControlsSample.HumanInTheLoopPage"
             x:Name="ThisPage"
             Title="Human in the Loop">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🗑️" Clicked="OnClearClicked" />
    </ContentPage.ToolbarItems>

    <controls:CopilotChatView Session="{Binding Source={x:Reference ThisPage}, Path=Session}"
        WelcomeMessage="I'm a plan assistant. Ask me to do something and I'll create a plan for your approval before executing."
        WelcomeIcon="📋">
        <controls:CopilotChatView.SuggestionPrompts>
            <x:String>Create a plan to organize my desk</x:String>
            <x:String>Plan how to learn a new language</x:String>
            <x:String>Help me plan a weekend trip</x:String>
        </controls:CopilotChatView.SuggestionPrompts>
        <controls:CopilotChatView.ContentTemplates>
            <chat:TextContentTemplate Role="User" />
            <chat:TextContentTemplate Role="Assistant" />
            <chat:FunctionCallTemplate />
            <chat:FunctionResultTemplate />
            <chat:ToolApprovalTemplate ToolName="create_plan" ViewType="{x:Type local:PlanStepsView}" />
            <chat:ErrorContentTemplate />
            <chat:DefaultContentTemplate />
        </controls:CopilotChatView.ContentTemplates>
    </controls:CopilotChatView>
</ContentPage>
