<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Microsoft.Maui.AI.Chat.Controls;assembly=Microsoft.Maui.AI.Chat.Controls"
             xmlns:chat="clr-namespace:Microsoft.Maui.AI.Chat.Controls;assembly=Microsoft.Maui.AI.Chat.Controls"
             x:Class="AiControlsSample.HumanInTheLoopPage"
             x:Name="ThisPage"
             Title="Human in the Loop">

    <Grid ColumnDefinitions="*,Auto">
        <!-- Chat panel -->
        <controls:CopilotChatView Session="{Binding Source={x:Reference ThisPage}, Path=Session}">
            <controls:CopilotChatView.ContentTemplates>
                <chat:TextContentTemplate Role="User" />
                <chat:TextContentTemplate Role="Assistant" />
                <chat:FunctionCallTemplate />
                <chat:FunctionResultTemplate />
                <chat:ToolApprovalTemplate />
                <chat:ErrorContentTemplate />
                <chat:DefaultContentTemplate />
            </controls:CopilotChatView.ContentTemplates>
        </controls:CopilotChatView>

        <!-- Plan card panel (right side) -->
        <Border x:Name="PlanPanel" Grid.Column="1"
                IsVisible="False"
                WidthRequest="320"
                Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                StrokeShape="Rectangle" StrokeThickness="1"
                Padding="16">
            <Grid RowDefinitions="Auto,*,Auto">
                <Label Text="📋 Plan" FontSize="18" FontAttributes="Bold" Margin="0,0,0,12" />

                <ScrollView Grid.Row="1">
                    <VerticalStackLayout x:Name="StepsLayout" Spacing="8" />
                </ScrollView>

                <HorizontalStackLayout x:Name="ConfirmButtons" Grid.Row="2"
                                       Spacing="8" Margin="0,12,0,0" IsVisible="False">
                    <Button Text="✅ Confirm" FontSize="12" Padding="10,6" CornerRadius="6"
                            BackgroundColor="#22C55E" TextColor="White"
                            Clicked="OnConfirmClicked" />
                    <Button Text="❌ Reject" FontSize="12" Padding="10,6" CornerRadius="6"
                            BackgroundColor="#EF4444" TextColor="White"
                            Clicked="OnRejectClicked" />
                </HorizontalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
