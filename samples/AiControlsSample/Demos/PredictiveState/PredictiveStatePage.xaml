<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Microsoft.Maui.AI.Chat.Controls;assembly=Microsoft.Maui.AI.Chat.Controls"
             xmlns:chat="clr-namespace:Microsoft.Maui.AI.Chat.Controls;assembly=Microsoft.Maui.AI.Chat.Controls"
             x:Class="AiControlsSample.PredictiveStatePage"
             x:Name="ThisPage"
             Title="Predictive State Updates">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🗑️" Clicked="OnClearClicked" />
    </ContentPage.ToolbarItems>

    <Grid ColumnDefinitions="*,*" ColumnSpacing="0">

        <!-- LEFT: Document Editor -->
        <Grid Grid.Column="0" RowDefinitions="Auto,*"
              BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A2E}">

            <!-- Header -->
            <Grid Padding="16,12" ColumnDefinitions="*,Auto"
                  BackgroundColor="{AppThemeBinding Light=White, Dark=#262640}">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="📝" FontSize="18" VerticalOptions="Center" />
                    <Label Text="Document Editor" FontSize="18" FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Label x:Name="WritingIndicator" Text="✍️ Writing..." FontSize="14"
                           TextColor="{AppThemeBinding Light=#6366F1, Dark=#818CF8}"
                           VerticalOptions="Center" IsVisible="False" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Document content -->
            <ScrollView Grid.Row="1" Padding="20">
                <Label x:Name="DocumentLabel" FontSize="14" LineBreakMode="WordWrap"
                       Text="Ask the AI to write something..."
                       TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}" />
            </ScrollView>
        </Grid>

        <!-- RIGHT: Chat Panel -->
        <controls:CopilotChatView Grid.Column="1"
            Session="{Binding Source={x:Reference ThisPage}, Path=Session}"
            WelcomeMessage="I'll write content that appears in the document editor — watch it update as I work!"
            WelcomeIcon="📝">
            <controls:CopilotChatView.SuggestionPrompts>
                <x:String>Write a paragraph about space exploration</x:String>
                <x:String>Draft a short email to a colleague</x:String>
                <x:String>Write a product description for a smartwatch</x:String>
            </controls:CopilotChatView.SuggestionPrompts>
            <controls:CopilotChatView.ContentTemplates>
                <chat:TextContentTemplate Role="User" />
                <chat:TextContentTemplate Role="Assistant" />
                <chat:FunctionCallTemplate />
                <chat:FunctionResultTemplate />
                <chat:ToolApprovalTemplate />
                <chat:ErrorContentTemplate />
                <chat:DefaultContentTemplate />
            </controls:CopilotChatView.ContentTemplates>
        </controls:CopilotChatView>
    </Grid>
</ContentPage>
