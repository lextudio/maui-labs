@page "/human-in-the-loop"
@using Microsoft.AspNetCore.Components.AI
@using Microsoft.Extensions.AI
@using System.Text.Json
@inject IChatClient ChatClient

<div style="display: flex; gap: 1rem; height: 100%;">
    <div style="flex: 1;">
        <ChatPage Agent="@_agent" Suggestions="@_suggestions" Placeholder="Ask me to plan something..." />
    </div>
    @if (_steps is not null)
    {
        <div style="flex: 0 0 280px; padding: 1rem; border: 1px solid #45475a; border-radius: 8px;">
            <h4 style="margin-top: 0;">📋 Plan</h4>
            @for (int i = 0; i < _steps.Count; i++)
            {
                <div style="margin: 0.5rem 0;">
                    <span>@(_steps[i].IsCompleted ? "✅" : "⬜")</span>
                    <span style="opacity: @(_steps[i].IsCompleted ? 0.6 : 1)">@_steps[i].Description</span>
                </div>
            }
            @if (_showConfirmButtons)
            {
                <div style="margin-top: 1rem; display: flex; gap: 0.5rem;">
                    <button class="btn-confirm" @onclick="OnConfirm">✓ Confirm</button>
                    <button class="btn-reject" @onclick="OnReject">✗ Reject</button>
                </div>
            }
        </div>
    }
</div>

@code {
    private UIAgent _agent = default!;
    private AgentContext? _context;
    private List<Suggestion> _suggestions = default!;
    private List<PlanStep>? _steps;
    private bool _showConfirmButtons;

    protected override void OnInitialized()
    {
        var tools = new List<AITool>
        {
            AIFunctionFactory.Create(CreatePlan, "create_plan", "Create a plan with the given steps for the user to review."),
            AIFunctionFactory.Create(UpdatePlanStep, "update_plan_step", "Mark a plan step as completed. Step index is 0-based.")
        };

        var chatOptions = new ChatOptions
        {
            Instructions = """
                You are a plan assistant. When the user asks you to do something:
                1. Create a plan by calling create_plan with a list of step descriptions.
                2. After the plan is shown, WAIT for the user to confirm or reject. Do NOT proceed until they reply.
                3. If the user confirms, execute each step one by one, calling update_plan_step to mark each as completed.
                4. If the user rejects, acknowledge and ask what they'd like to change.

                Always create 3-5 concrete steps that clearly describe what will happen.
                """,
            Tools = [.. tools]
        };

        _agent = new UIAgent(ChatClient, chatOptions);
        _context = new AgentContext(_agent);
        _suggestions =
        [
            new() { Label = "Organize a birthday party", Prompt = "Organize a birthday party" },
            new() { Label = "Plan a hiking trip", Prompt = "Plan a weekend hiking trip" },
            new() { Label = "Set up a home office", Prompt = "Set up a home office" },
        ];
    }

    [System.ComponentModel.Description("Create a plan with the given steps for the user to review.")]
    private string CreatePlan(
        [System.ComponentModel.Description("JSON array of step descriptions")] string steps_json)
    {
        var steps = JsonSerializer.Deserialize<List<string>>(steps_json) ?? [];
        _steps = steps.Select(s => new PlanStep { Description = s }).ToList();
        _showConfirmButtons = true;
        InvokeAsync(StateHasChanged);
        return "Plan created and shown to user. Waiting for confirmation.";
    }

    [System.ComponentModel.Description("Mark a plan step as completed by zero-based index.")]
    private string UpdatePlanStep(
        [System.ComponentModel.Description("Zero-based step index to mark as completed")] int step_index)
    {
        if (_steps is not null && step_index >= 0 && step_index < _steps.Count)
        {
            _steps[step_index].IsCompleted = true;
            InvokeAsync(StateHasChanged);
        }
        return $"Step {step_index} marked as completed.";
    }

    private async Task OnConfirm()
    {
        _showConfirmButtons = false;
        if (_context is not null)
            await _context.SendMessageAsync("I confirm the plan. Please proceed with execution.");
    }

    private async Task OnReject()
    {
        _showConfirmButtons = false;
        if (_context is not null)
            await _context.SendMessageAsync("I reject this plan. Please suggest changes.");
    }

    private class PlanStep
    {
        public string Description { get; init; } = string.Empty;
        public bool IsCompleted { get; set; }
    }
}
