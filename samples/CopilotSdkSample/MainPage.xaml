<ContentPage x:Class="CopilotSdkSample.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CopilotSdkSample"
             Title="Copilot Chat">

    <Grid RowDefinitions="*,Auto" Padding="10">

        <!-- Chat messages -->
        <CollectionView x:Name="MessagesView"
                        ItemsSource="{Binding Messages}"
                        Grid.Row="0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:ChatMessageItem">
                    <Grid Padding="4">
                        <Frame Padding="12,8"
                               CornerRadius="12"
                               BackgroundColor="{Binding BackgroundColor}"
                               HorizontalOptions="{Binding Alignment}"
                               MaximumWidthRequest="500">
                            <Label Text="{Binding Text}"
                                   TextColor="{Binding TextColor}" />
                        </Frame>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Input area -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="0,8,0,0">
            <Entry x:Name="MessageEntry"
                   Placeholder="Type a message..."
                   ReturnType="Send"
                   Completed="OnSendClicked"
                   IsEnabled="{Binding IsNotBusy}" />
            <Button Text="Send"
                    Grid.Column="1"
                    Clicked="OnSendClicked"
                    IsEnabled="{Binding IsNotBusy}" />
        </Grid>

    </Grid>

</ContentPage>
