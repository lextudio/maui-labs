<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CopilotChat.Sample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CopilotChat.Sample"
    Title="Copilot Chat">

    <TabBar>
        <ShellContent Title="Home" ContentTemplate="{DataTemplate local:MainPage}" Route="home" />
        <ShellContent Title="Chat" ContentTemplate="{DataTemplate local:ChatPage}" Route="chat" />
        <ShellContent Title="Settings" ContentTemplate="{DataTemplate local:SettingsPage}" Route="settings" />
    </TabBar>

</Shell>
