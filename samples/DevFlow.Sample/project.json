{
  "name": "DevFlow.Sample",
  "targets": {
    "build:android": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{workspaceRoot}/artifacts/bin/DevFlow.Sample/Debug/net10.0-android",
        "{workspaceRoot}/artifacts/obj/DevFlow.Sample/Debug/net10.0-android"
      ],
      "options": {
        "command": "dotnet build samples/DevFlow.Sample/DevFlow.Sample.csproj -f net10.0-android -c Debug --nologo -v q -p:EmbedAssembliesIntoApk=true -p:MauiDevFlowPort=58100"
      }
    },
    "build:ios": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{workspaceRoot}/artifacts/bin/DevFlow.Sample/Debug/net10.0-ios",
        "{workspaceRoot}/artifacts/obj/DevFlow.Sample/Debug/net10.0-ios"
      ],
      "options": {
        "command": "dotnet build samples/DevFlow.Sample/DevFlow.Sample.csproj -f net10.0-ios -c Debug --nologo -v q -p:_DeviceTarget=simulator -p:RuntimeIdentifier=iossimulator-$(uname -m | sed 's/x86_64/x64/')"
      }
    },
    "build:maccatalyst": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{workspaceRoot}/artifacts/bin/DevFlow.Sample/Debug/net10.0-maccatalyst",
        "{workspaceRoot}/artifacts/obj/DevFlow.Sample/Debug/net10.0-maccatalyst"
      ],
      "options": {
        "command": "dotnet build samples/DevFlow.Sample/DevFlow.Sample.csproj -f net10.0-maccatalyst -c Debug --nologo -v q"
      }
    },
    "build:windows": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{workspaceRoot}/artifacts/bin/DevFlow.Sample/Debug/net10.0-windows10.0.19041.0",
        "{workspaceRoot}/artifacts/obj/DevFlow.Sample/Debug/net10.0-windows10.0.19041.0"
      ],
      "options": {
        "command": "dotnet build samples/DevFlow.Sample/DevFlow.Sample.csproj -f net10.0-windows10.0.19041.0 -c Debug --nologo -v q"
      }
    }
  }
}
