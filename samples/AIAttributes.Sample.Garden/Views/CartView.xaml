<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AIAttributes.Sample.Garden"
             xmlns:vm="clr-namespace:AIAttributes.Sample.Garden.ViewModels"
             x:Class="AIAttributes.Sample.Garden.Views.CartView"
             x:DataType="vm:CartViewModel"
             local:ViewModelBinder.Type="{x:Type vm:CartViewModel}"
             BackgroundColor="Transparent">

    <Grid RowDefinitions="*,Auto" RowSpacing="0">

        <!-- Normal mode: card layout -->
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None"
                        BackgroundColor="Transparent"
                        IsVisible="{Binding IsNormalMode}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:CartItemViewModel">
                    <Grid Padding="12,4">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}"
                                Stroke="{AppThemeBinding Light={StaticResource CardStrokeLight}, Dark={StaticResource CardStrokeDark}}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="10,8">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Text="{Binding Emoji}"
                                       FontFamily="FluentFilled"
                                       FontSize="{StaticResource FontSizeTitle}"
                                       TextColor="{StaticResource Primary}"
                                       VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontSize="{StaticResource FontSizeBody}" FontAttributes="Bold" />
                                    <Label Text="{Binding QuantityLine}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24" Spacing="6"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <Label Text="&#xE769;" FontFamily="FluentFilled"
                           FontSize="{StaticResource FontSizeDisplay}" HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}" />
                    <Label Text="Your cart is empty."
                           FontSize="{StaticResource FontSizeBody}" HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                    <Label Text="Ask Sage to add seeds, soil, or tools."
                           FontSize="{StaticResource FontSizeCaption}" HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextTertiaryLight}, Dark={StaticResource TextTertiaryDark}}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Compact mode: dense rows -->
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding Items}"
                        SelectionMode="None"
                        BackgroundColor="Transparent"
                        IsVisible="{Binding IsCompactMode}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:CartItemViewModel">
                    <Grid Padding="14,3" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                        <Label Text="{Binding Emoji}"
                               FontFamily="FluentFilled"
                               FontSize="{StaticResource FontSizeBody}"
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding Name}"
                               FontSize="{StaticResource FontSizeBody}" FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <Label Grid.Column="3"
                               Text="{Binding QuantityLine}"
                               FontSize="{StaticResource FontSizeCaption}"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="Cart is empty."
                       FontSize="{StaticResource FontSizeCaption}" FontAttributes="Italic"
                       Padding="14,8"
                       TextColor="{AppThemeBinding Light={StaticResource TextTertiaryLight}, Dark={StaticResource TextTertiaryDark}}" />
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Checkout footer — hidden when cart is empty -->
        <Border Grid.Row="1"
                BackgroundColor="Transparent"
                StrokeThickness="0"
                Padding="12,10"
                IsVisible="{Binding HasItems}">
            <Button HorizontalOptions="Fill"
                    Text="{Binding CartTotal, StringFormat='Checkout — {0}'}"
                    FontSize="{StaticResource FontSizeBody}" FontAttributes="Bold"
                    Padding="16,8"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource White}"
                    CornerRadius="10"
                    Command="{Binding CheckoutCommand}" />
        </Border>
    </Grid>

</ContentView>
