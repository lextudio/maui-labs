{
  "agent": {
    "name": "Microsoft.Maui.DevFlow.Agent",
    "version": "0.1.0-preview",
    "framework": "maui",
    "frameworkVersion": "10.0.0"
  },
  "capabilities": {
    "ui.tree": {
      "version": 1,
      "features": ["css-selector", "type", "text", "accessibility-id"]
    },
    "ui.actions": {
      "version": 1,
      "features": ["tap", "fill", "clear", "focus", "scroll", "navigate", "resize", "back", "key", "gesture", "batch", "properties"]
    },
    "ui.screenshot": {
      "version": 1,
      "features": ["element", "fullscreen", "selector"]
    },
    "webview": {
      "version": 1,
      "features": ["evaluate", "contexts", "source", "dom", "dom-query", "network", "console", "screenshot"]
    },
    "network": {
      "version": 1,
      "features": ["list", "detail", "clear", "stream"]
    },
    "logs": {
      "version": 1,
      "features": ["list", "stream"]
    },
    "device.info": {
      "version": 1,
      "features": ["app", "device", "display", "battery", "connectivity"]
    },
    "device.sensors": {
      "version": 1,
      "features": ["list", "start", "stop", "stream"]
    },
    "device.jobs": {
      "version": 1,
      "features": ["list", "run"],
      "supported": true
    },
    "storage.preferences": {
      "version": 1,
      "features": ["list", "get", "set", "delete", "clear"]
    },
    "storage.secure": {
      "version": 1,
      "features": ["get", "set", "delete", "clear"]
    },
    "storage.files": {
      "version": 1,
      "features": ["roots", "list", "download", "upload", "delete"]
    },
    "profiler": {
      "version": 1,
      "features": ["capabilities", "sessions", "samples", "markers", "spans", "hotspots"]
    },
    "theme": {
      "version": 1,
      "supported": true,
      "features": ["get", "set"]
    },
    "app.theme": {
      "version": 1,
      "supported": true,
      "features": ["get", "set"]
    },
    "invoke": {
      "version": 1,
      "features": ["actions"]
    }
  }
}
