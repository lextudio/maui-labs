{
  "installation": {
    "version": "22.7.1",
    "plugins": {
      "@nx/dotnet": "22.7.0"
    }
  },
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "plugins": [
    "@nx/dotnet"
  ],
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.Tests/**/*",
      "!{projectRoot}/**/bin/**/*",
      "!{projectRoot}/**/obj/**/*"
    ]
  },
  "targetDefaults": {
    "restore": {
      "cache": false
    },
    "build": {
      "outputs": [
        "{workspaceRoot}/artifacts/bin/{projectName}",
        "{workspaceRoot}/artifacts/obj/{projectName}"
      ]
    },
    "build:release": {
      "outputs": [
        "{workspaceRoot}/artifacts/bin/{projectName}",
        "{workspaceRoot}/artifacts/obj/{projectName}"
      ]
    },
    "test": {
      "outputs": [
        "{workspaceRoot}/artifacts/TestResults",
        "{projectRoot}/TestResults"
      ]
    },
    "pack": {
      "cache": false
    },
    "publish": {
      "cache": false
    }
  }
}
