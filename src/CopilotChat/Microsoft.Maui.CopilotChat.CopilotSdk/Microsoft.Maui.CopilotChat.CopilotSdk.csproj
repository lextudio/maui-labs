<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Microsoft.Maui.CopilotChat.CopilotSdk</RootNamespace>
    <IsPackable>true</IsPackable>
    <IsShipping>true</IsShipping>
    <PackageId>Microsoft.Maui.CopilotChat.CopilotSdk</PackageId>
    <Description>Copilot SDK adapter for Microsoft.Maui.CopilotChat. Provides CopilotSdkChatClient, an IChatClient backed by the GitHub Copilot SDK.</Description>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="GitHub.Copilot.SDK" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Microsoft.Maui.CopilotChat\Microsoft.Maui.CopilotChat.csproj" />
  </ItemGroup>

</Project>
