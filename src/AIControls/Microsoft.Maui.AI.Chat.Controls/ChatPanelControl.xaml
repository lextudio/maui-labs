<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Microsoft.Maui.AI.Chat.Controls.ChatPanelControl"
             x:Name="Self">

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto" RowSpacing="0">

        <!-- Row 0: Header (optional) -->
        <ContentView x:Name="HeaderContent" Grid.Row="0" IsVisible="False" />

        <!-- Row 1: Welcome message (visible only when no messages and WelcomeMessage is set) -->
        <!-- Also holds the messages CollectionView which overlays the welcome -->
        <Grid Grid.Row="1">
            <!-- Welcome overlay -->
            <VerticalStackLayout x:Name="WelcomePanel"
                                 IsVisible="False"
                                 VerticalOptions="Center" HorizontalOptions="Center"
                                 Spacing="12" Padding="24">
                <Label x:Name="WelcomeIconLabel" Text="💬" FontSize="48"
                       HorizontalOptions="Center" />
                <Label x:Name="WelcomeMessageLabel" FontSize="16"
                       HorizontalTextAlignment="Center"
                       Opacity="0.7" />
            </VerticalStackLayout>

            <!-- Messages -->
            <CollectionView x:Name="ChatMessages"
                            AutomationId="ChatMessages"
                            Margin="12,8,12,0" />
        </Grid>

        <!-- Row 2: Busy indicator -->
        <ActivityIndicator Grid.Row="2"
                           AutomationId="ChatBusyIndicator"
                           IsRunning="{Binding IsBusy, Source={x:Reference Self}}"
                           IsVisible="{Binding IsBusy, Source={x:Reference Self}}"
                           Color="{DynamicResource ExtensionsAI.Send.Background}"
                           Margin="0,6" />

        <!-- Row 3: Suggestion chips (visible when SuggestionPrompts is set and no messages) -->
        <FlexLayout x:Name="SuggestionsPanel" Grid.Row="3"
                    IsVisible="False"
                    Wrap="Wrap" JustifyContent="Center"
                    Margin="12,4" />

        <!-- Row 4: Footer (optional) -->
        <ContentView x:Name="FooterContent" Grid.Row="4" IsVisible="False" />

        <!-- Row 5: Input Area -->
        <Border x:Name="InputAreaBorder" Grid.Row="5" Margin="12,8,12,12" Padding="6"
                BackgroundColor="{DynamicResource ExtensionsAI.Input.Background}"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle x:Name="InputAreaShape" CornerRadius="14" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                <Entry x:Name="InputEntry"
                       Placeholder="{Binding Placeholder, Source={x:Reference Self}}"
                       AutomationId="ChatInput"
                       Text="{Binding Text, Source={x:Reference Self}, Mode=TwoWay}"
                       Completed="OnInputCompleted"
                       FontSize="14"
                       BackgroundColor="Transparent" />
                <Button x:Name="SendButton" Grid.Column="1"
                        Text="{Binding SendButtonText, Source={x:Reference Self}}"
                        AutomationId="SendMessageButton"
                        Clicked="OnSendButtonClicked"
                        BackgroundColor="{DynamicResource ExtensionsAI.Send.Background}"
                        TextColor="{DynamicResource ExtensionsAI.Send.TextColor}"
                        FontSize="16"
                        WidthRequest="42" HeightRequest="42"
                        CornerRadius="12" Padding="0" />
            </Grid>
        </Border>
    </Grid>

</ContentView>
