<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net10.0</TargetFrameworks>
    <AssemblyName>Microsoft.Maui.Labs.HotReload</AssemblyName>
    <RootNamespace>Microsoft.Maui.Labs.HotReload</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="..\Microsoft.Maui.HotReload.SourceGen\**" />
  </ItemGroup>

  <PropertyGroup>
    <!-- NuGet package information -->
    <IsShipping>true</IsShipping>
    <IsPackable>true</IsPackable>
    <PackageId>Microsoft.Maui.Labs.HotReload</PackageId>
    <Description>Provides a MetadataUpdateHandler for .NET MAUI hot reload. Register any IHotReloadable instance to receive OnHotReload() callbacks when their type is hot-reloaded.</Description>
    <PackageTags>$(DefaultPackageTags);hotreload;developer-tools</PackageTags>
    <SuppressFinalPackageVersion>true</SuppressFinalPackageVersion>
  </PropertyGroup>

  <!-- Microsoft.Maui.Core is only available for net10.0+, not netstandard -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Microsoft.Maui.Core" />
  </ItemGroup>

  <!-- Reference the source generator as an analyzer/generator -->
  <ItemGroup>
    <ProjectReference Include="..\Microsoft.Maui.HotReload.SourceGen\Microsoft.Maui.HotReload.SourceGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- Pack the source generator DLL into the correct NuGet analyzers path.
       Uses MSBuild's GetTargetPath to locate the DLL regardless of artifacts layout. -->
  <Target Name="IncludeSourceGenInPackage" BeforeTargets="_GetPackageFiles">
    <MSBuild Projects="..\Microsoft.Maui.HotReload.SourceGen\Microsoft.Maui.HotReload.SourceGen.csproj"
             Targets="GetTargetPath"
             Properties="Configuration=$(Configuration)">
      <Output TaskParameter="TargetOutputs" ItemName="_SourceGenDll" />
    </MSBuild>
    <ItemGroup>
      <None Include="@(_SourceGenDll)" Pack="true" PackagePath="analyzers/dotnet/cs/" Visible="false" />
    </ItemGroup>
  </Target>

</Project>
