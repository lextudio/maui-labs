<Project>
	<ItemGroup Condition="'$(Configuration)' == 'Debug'">
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="10.0.0" />
		<PackageReference Include="Redth.MauiDevFlow.Agent" Version="0.18.0" />
		<Compile Include="$(MSBuildThisFileDirectory)Shared/RuntimeDebug/SampleRuntimeDebugExtensions.cs"
		         Link="Shared/RuntimeDebug/SampleRuntimeDebugExtensions.cs"
		         Visible="false" />
	</ItemGroup>

	<PropertyGroup Condition="'$(Configuration)' == 'Debug' and $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">
		<CodesignEntitlements>$(MSBuildThisFileDirectory)Shared/RuntimeDebug/Entitlements.Debug.plist</CodesignEntitlements>
	</PropertyGroup>
</Project>
