<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net11.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Suppress platform compatibility warnings: benchmarks reference maccatalyst DLL from net11.0 -->
    <NoWarn>CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" Version="0.14.0" />
    <PackageReference Include="Microsoft.Maui.Core" Version="11.0.0-preview.2.26152.10" />
    <PackageReference Include="Microsoft.Maui.Controls" Version="11.0.0-preview.2.26152.10" />
    <PackageReference Include="Microsoft.Maui.Graphics" Version="11.0.0-preview.2.26152.10" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="Comet">
      <HintPath>..\..\src\Comet\bin\$(Configuration)\net11.0-maccatalyst\Comet.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Comet.SourceGenerator\Comet.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
