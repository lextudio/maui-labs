{
  "name": "Microsoft.Maui.DevFlow.Agent.IntegrationTests",
  "implicitDependencies": [
    "DevFlow.Sample"
  ],
  "targets": {
    "test:android": {
      "executor": "nx:run-commands",
      "cache": false,
      "parallelism": false,
      "options": {
        "command": "dotnet test src/DevFlow/Microsoft.Maui.DevFlow.Agent.IntegrationTests/Microsoft.Maui.DevFlow.Agent.IntegrationTests.csproj -c Debug -p:DevFlowIntegrationPlatform=android --logger \"trx;LogFileName=devflow-integration-android.trx\" --logger \"console;verbosity=normal\" --results-directory artifacts/TestResults/devflow-integration/android",
        "env": {
          "DEVFLOW_TEST_PLATFORM": "android",
          "DEVFLOW_TEST_PORT": "58100"
        }
      }
    },
    "test:ios": {
      "executor": "nx:run-commands",
      "cache": false,
      "parallelism": false,
      "options": {
        "command": "dotnet test src/DevFlow/Microsoft.Maui.DevFlow.Agent.IntegrationTests/Microsoft.Maui.DevFlow.Agent.IntegrationTests.csproj -c Debug -p:DevFlowIntegrationPlatform=ios --logger \"trx;LogFileName=devflow-integration-ios.trx\" --logger \"console;verbosity=normal\" --results-directory artifacts/TestResults/devflow-integration/ios",
        "env": {
          "DEVFLOW_TEST_PLATFORM": "ios",
          "DEVFLOW_TEST_PORT": "58100"
        }
      }
    },
    "test:maccatalyst": {
      "executor": "nx:run-commands",
      "cache": false,
      "parallelism": false,
      "options": {
        "command": "dotnet test src/DevFlow/Microsoft.Maui.DevFlow.Agent.IntegrationTests/Microsoft.Maui.DevFlow.Agent.IntegrationTests.csproj -c Debug -p:DevFlowIntegrationPlatform=maccatalyst --logger \"trx;LogFileName=devflow-integration-maccatalyst.trx\" --logger \"console;verbosity=normal\" --results-directory artifacts/TestResults/devflow-integration/maccatalyst",
        "env": {
          "DEVFLOW_TEST_PLATFORM": "maccatalyst",
          "DEVFLOW_TEST_PORT": "58100"
        }
      }
    },
    "test:windows": {
      "executor": "nx:run-commands",
      "cache": false,
      "parallelism": false,
      "options": {
        "command": "dotnet test src/DevFlow/Microsoft.Maui.DevFlow.Agent.IntegrationTests/Microsoft.Maui.DevFlow.Agent.IntegrationTests.csproj -c Debug -p:DevFlowIntegrationPlatform=windows --logger \"trx;LogFileName=devflow-integration-windows.trx\" --logger \"console;verbosity=normal\" --results-directory artifacts/TestResults/devflow-integration/windows",
        "env": {
          "DEVFLOW_TEST_PLATFORM": "windows",
          "DEVFLOW_TEST_PORT": "58100"
        }
      }
    }
  }
}
