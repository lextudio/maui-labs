<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0-android;net10.0-ios;net10.0-maccatalyst;net10.0-macos</TargetFrameworks>
    <TargetFrameworks Condition="$([MSBuild]::IsOSPlatform('windows'))">$(TargetFrameworks);net10.0-windows10.0.19041.0</TargetFrameworks>
    <UseMaui>true</UseMaui>
    <SingleProject>true</SingleProject>
    <IsPackable>true</IsPackable>

    <PackageId>Microsoft.Maui.DevFlow.Agent</PackageId>
    <IsShipping>true</IsShipping>
    <Description>In-app agent for .NET MAUI automation. Exposes visual tree, element interactions, and screenshots via HTTP/JSON API.</Description>
    <PackageTags>maui;automation;testing;visual-tree;agent</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Microsoft.Maui.DevFlow.Agent.Core\Microsoft.Maui.DevFlow.Agent.Core.csproj" />
  </ItemGroup>

  <!-- macOS AppKit backend -->
  <ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'macos'">
    <PackageReference Include="Platform.Maui.MacOS" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Maui.Controls" />
  </ItemGroup>

  <!-- Source generator for auto-initialization (interceptor-based) -->
  <ItemGroup>
    <ProjectReference Include="..\Microsoft.Maui.DevFlow.Agent.SourceGen\Microsoft.Maui.DevFlow.Agent.SourceGen.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- Include .targets files in NuGet package for MSBuild port configuration -->
  <ItemGroup>
    <None Include="build\**" Pack="true" PackagePath="build\" />
    <None Include="buildTransitive\**" Pack="true" PackagePath="buildTransitive\" />
  </ItemGroup>

  <!-- Pack the source generator DLL into the NuGet package -->
  <PropertyGroup>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_PackSourceGenerator</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <Target Name="_PackSourceGenerator">
    <MSBuild Projects="..\Microsoft.Maui.DevFlow.Agent.SourceGen\Microsoft.Maui.DevFlow.Agent.SourceGen.csproj"
             Targets="GetTargetPath"
             Properties="TargetFramework=netstandard2.0">
      <Output TaskParameter="TargetOutputs" ItemName="_SourceGenDll" />
    </MSBuild>
    <ItemGroup>
      <TfmSpecificPackageFile Include="@(_SourceGenDll)" PackagePath="analyzers/dotnet/cs" />
    </ItemGroup>
  </Target>

</Project>
