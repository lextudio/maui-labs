<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Microsoft.Maui.AI.Controls.Controls.AgentLoadingIndicator"
             HeightRequest="30"
             WidthRequest="60">

    <HorizontalStackLayout x:Name="DotsContainer"
                           Spacing="6"
                           HorizontalOptions="Center"
                           VerticalOptions="Center">
        <BoxView x:Name="Dot1"
                 Color="{AppThemeBinding Light=#999999, Dark=#888888}"
                 CornerRadius="5"
                 WidthRequest="10"
                 HeightRequest="10"
                 Opacity="0.3" />
        <BoxView x:Name="Dot2"
                 Color="{AppThemeBinding Light=#999999, Dark=#888888}"
                 CornerRadius="5"
                 WidthRequest="10"
                 HeightRequest="10"
                 Opacity="0.3" />
        <BoxView x:Name="Dot3"
                 Color="{AppThemeBinding Light=#999999, Dark=#888888}"
                 CornerRadius="5"
                 WidthRequest="10"
                 HeightRequest="10"
                 Opacity="0.3" />
    </HorizontalStackLayout>

</ContentView>
